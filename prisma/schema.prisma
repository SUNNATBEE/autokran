generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Admin {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  username String @unique
  password String
}

model Sponsor {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  logoUrl      String
  websiteUrl   String?
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Crane {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  modelName       String
  brand           String?  // XCMG, SANY, ZOOMLION, ...
  capacity        Float    // Lifting capacity in tons
  boomLength      Float    // Main boom length in meters
  auxBoomLength   Float?   // Max / auxiliary boom length in meters
  price           String   // Legacy free-text price (kept for backward compat)
  pricePerMonth   Int?     // Numeric monthly price in UZS — drives discount math
  discountPercent Int      @default(0) // 0..90; 0 = no discount
  available       Boolean  @default(true) // false = hidden from the public site
  displayOrder    Int      @default(0) // ascending sort on the public site
  description     String
  images          String[] // Array of image URLs (/uploads/... or /images/...)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// Daily page-view counter for the in-panel visitor statistics.
model Visit {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  day   String @unique // "YYYY-MM-DD" (UTC)
  count Int    @default(0)
}

model GlobalSettings {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  phoneNumbers   String[]
  telegramBot    String?
  address        String?
  seoTitle       String?
  seoDescription String?
}

model RentalOrder {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  phone      String
  location   String
  craneModel String?
  status     String   @default("new")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ContactRequest {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  phone     String
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
