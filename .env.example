# Server
PORT=4000
# Comma-separated list of allowed CORS origins (the frontend URL)
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# Auth — must match the frontend's JWT_SECRET.
# REQUIRED in production. Generate a strong value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change_me_in_production

# Admin accounts as a JSON array. REQUIRED in production (no credentials in
# source control). In development a built-in fallback is used if unset.
# Example:
# ADMIN_ACCOUNTS=[{"username":"shah","password":"STRONG_PASSWORD","role":"super_admin","displayName":"Shah"},{"username":"otabek","password":"STRONG_PASSWORD","role":"order_manager","displayName":"Otabek"}]
ADMIN_ACCOUNTS=

# Telegram Bot (keep these secret — rotate immediately if ever exposed)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Prisma / MongoDB connection string (optional — falls back to JSON file store
# when empty). Use a MongoDB Atlas SRV URL (Atlas is a replica set, required by
# Prisma). Include the database name in the path.
# Example:
# DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/crane_rental?retryWrites=true&w=majority"
DATABASE_URL=
